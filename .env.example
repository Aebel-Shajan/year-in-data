# Cloudflare R2 credentials
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key

# GitHub (for contributions extractor)
GITHUB_TOKEN=ghp_xxxx

# Google Drive public share URL (right-click folder → Share → Anyone with the link)
DRIVE_SHARE_URL=https://drive.google.com/drive/folders/xxxx

# The Gym Group credentials (for gym visits extractor)
GYM_GROUP_USERNAME=your_email
GYM_GROUP_PASSWORD=your_password

# Non-sensitive settings (bucket name, public URL, username) live in config/config.toml
