# Local development — uses MinIO instead of Cloudflare R2.
# Copy to .env when working locally.

R2_ACCESS_KEY_ID=minioadmin
R2_SECRET_ACCESS_KEY=minioadmin
R2_ACCOUNT_ID=local

GITHUB_TOKEN=ghp_xxxx
RUNTIME_ENV=local


# Google Drive public share URL (right-click folder → Share → Anyone with the link)
DRIVE_SHARE_URL=https://drive.google.com/drive/folders/1Qt5_YOMUf5uCgMjs1g96X-hNsFlqEFc7?usp=sharing
# Non-sensitive settings (bucket name, public URL, username) live in config/config.toml
