<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.yearindata.screentime</string>

  <key>ProgramArguments</key>
  <array>
    <string>__UV__</string>
    <string>--directory</string>
    <string>__PROJECT_DIR__</string>
    <string>run</string>
    <string>python</string>
    <string>scripts/sync_screentime.py</string>
  </array>

  <key>StartCalendarInterval</key>
  <dict>
    <key>Hour</key>
    <integer>9</integer>
    <key>Minute</key>
    <integer>0</integer>
  </dict>

  <key>StandardOutPath</key>
  <string>__PROJECT_DIR__/logs/screentime.log</string>

  <key>StandardErrorPath</key>
  <string>__PROJECT_DIR__/logs/screentime.err</string>
</dict>
</plist>
